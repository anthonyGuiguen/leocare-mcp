# API Coherent Spark
COHERENT_API_URL=https://excel.uat.us.coherent.global/leocare/api/v3/folders/.../services/.../execute
COHERENT_SYNTHETIC_KEY=your-synthetic-key-here

# Version du modèle Coherent (optionnel — fallback sur la valeur par défaut du code)
COHERENT_VERSION_ID=3bdeb9de-ba23-4458-bccc-4e9eb7efff73

# Redis Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Vérification domaine OpenAI
OPENAI_DOMAIN_CHALLENGE=your-challenge-token-here

# Debug widget /quote (mettre "true" pour activer le panel debug, jamais en prod)
NEXT_PUBLIC_DEBUG_WIDGET=false
